// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  coordinator
  designer
  warehouse
  client
}

enum PipelineStage {
  new_inquiry
  ocular_scheduled
  proposal_sent
  reserved
  fully_booked
  done
  cancelled
}

enum EventStatus {
  planning
  production
  ready
  event_day
  done
  cancelled
}

enum EventType {
  wedding
  corporate
  birthday
  debut
  other
}

enum PaymentStatus {
  pending
  paid
  partial
  overdue
  refunded
}

enum PaymentType {
  downpayment
  midpayment
  balance
  addon
  refund
}

enum TaskPriority {
  low
  normal
  high
  urgent
}

enum ChecklistPhase {
  pre_production
  fabrication
  supplier
  load_in
  event_day
  load_out
  post_event
}

enum LogType {
  note
  incident
  change_request
  client_approval
  sign_off
  timeline_tick
}

enum ReservationStatus {
  reserved
  checked_out
  returned
  cancelled
}

enum ClientAccountStatus {
  pending
  approved
  suspended
}

// ─── MODELS ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(coordinator)
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime @default(now()) @map("created_at")

  coordinatedEvents Event[]        @relation("EventCoordinator")
  tasks             Task[]         @relation("AssignedTasks")
  doneTasks         Task[]         @relation("DoneTasks")
  uploadedPegs      MoodboardPeg[]
  clientAccount     ClientAccount?
  eventLogs         EventLog[]

  @@map("users")
}

model ClientAccount {
  id                  String              @id @default(cuid())
  userId              String              @unique @map("user_id")
  clientId            String?             @unique @map("client_id")
  accountStatus       ClientAccountStatus @default(pending) @map("account_status")
  emailVerified       Boolean             @default(false) @map("email_verified")
  verificationToken   String?             @unique @map("verification_token")
  verificationSentAt  DateTime?           @map("verification_sent_at")
  verifiedAt          DateTime?           @map("verified_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  approvedAt          DateTime?           @map("approved_at")
  approvedByUserId    String?             @map("approved_by_user_id")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id])

  @@map("client_accounts")
}

model Client {
  id            String        @id @default(cuid())
  fullName      String        @map("full_name")
  email         String?       @unique
  phone         String?
  instagram     String?
  address       String?
  referredBy    String?       @map("referred_by")
  notes         String?
  pipelineStage PipelineStage @default(new_inquiry) @map("pipeline_stage")
  inquiryDate   DateTime      @default(now()) @map("inquiry_date")
  ocularDate    DateTime?     @map("ocular_date")
  lastContacted DateTime?     @map("last_contacted")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  events        Event[]
  clientAccount ClientAccount?
  reviews       Review[]

  @@map("clients")
}

model Event {
  id             String      @id @default(cuid())
  eventId        String      @unique @map("event_id")
  name           String
  eventType      EventType   @default(wedding) @map("event_type")
  status         EventStatus @default(planning)
  clientId       String      @map("client_id")
  venueName      String?     @map("venue_name")
  venueAddress   String?     @map("venue_address")
  eventDate      DateTime    @map("event_date")
  eventTimeStart DateTime?   @map("event_time_start")
  eventTimeEnd   DateTime?   @map("event_time_end")
  callTime       DateTime?   @map("call_time")
  setupDeadline  DateTime?   @map("setup_deadline")
  coordinatorId  String?     @map("coordinator_id")
  teamNotes      String?     @map("team_notes")
  packageName    String?     @map("package_name")
  totalBudget    Decimal     @default(0) @map("total_budget")
  colorPalette   String?     @map("color_palette")
  internalNotes  String?     @map("internal_notes")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  client         Client          @relation(fields: [clientId], references: [id])
  coordinator    User?           @relation("EventCoordinator", fields: [coordinatorId], references: [id])
  quotes         Quote[]
  payments       Payment[]
  tasks          Task[]
  checklistItems ChecklistItem[]
  moodboardPegs  MoodboardPeg[]
  reservations   Reservation[]
  eventLogs      EventLog[]
  purchaseOrders PurchaseOrder[]
  files          EventFile[]
  afterEvent     AfterEvent?
  meetings       Meeting[]

  @@map("events")
}

model Quote {
  id                 String    @id @default(cuid())
  eventId            String    @map("event_id")
  version            Int       @default(1)
  label              String?
  isActive           Boolean   @default(true) @map("is_active")
  isApproved         Boolean   @default(false) @map("is_approved")
  approvedAt         DateTime? @map("approved_at")
  approvedBy         String?   @map("approved_by")
  packageName        String?   @map("package_name")
  packageDescription String?   @map("package_description")
  subtotal           Decimal   @default(0)
  discountType       String    @default("none") @map("discount_type")
  discountValue      Decimal   @default(0) @map("discount_value")
  discountReason     String?   @map("discount_reason")
  taxPercent         Decimal   @default(0) @map("tax_percent")
  grandTotal         Decimal   @default(0) @map("grand_total")
  downpaymentAmount  Decimal   @default(0) @map("downpayment_amount")
  downpaymentDue     DateTime? @map("downpayment_due")
  balanceDueDate     DateTime? @map("balance_due_date")
  inclusionsNote     String?   @map("inclusions_note")
  exclusionsNote     String?   @map("exclusions_note")
  termsNote          String?   @map("terms_note")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  event Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items QuoteItem[]

  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String  @map("quote_id")
  category    String?
  itemName    String  @map("item_name")
  description String?
  isAddon     Boolean @default(false) @map("is_addon")
  quantity    Decimal @default(1)
  unit        String  @default("pc")
  unitPrice   Decimal @default(0) @map("unit_price")
  totalPrice  Decimal @default(0) @map("total_price")
  sortOrder   Int     @default(0) @map("sort_order")

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

model Payment {
  id                String        @id @default(cuid())
  eventId           String        @map("event_id")
  quoteId           String?       @map("quote_id")
  paymentType       PaymentType   @default(downpayment) @map("payment_type")
  label             String?
  amount            Decimal
  dueDate           DateTime?     @map("due_date")
  paidDate          DateTime?     @map("paid_date")
  status            PaymentStatus @default(pending)
  method            String?
  referenceNumber   String?       @map("reference_number")
  proofOfPaymentUrl String?       @map("proof_of_payment_url")
  notes             String?
  createdAt         DateTime      @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Task {
  id               String       @id @default(cuid())
  eventId          String       @map("event_id")
  assignedTo       String?      @map("assigned_to")
  title            String
  description      String?
  category         String       @default("pre_production")
  priority         TaskPriority @default(normal)
  dueDate          DateTime?    @map("due_date")
  dueTime          DateTime?    @map("due_time")
  estimatedMinutes Int?         @map("estimated_minutes")
  isDone           Boolean      @default(false) @map("is_done")
  doneAt           DateTime?    @map("done_at")
  doneById         String?      @map("done_by_id")
  notes            String?
  createdAt        DateTime     @default(now()) @map("created_at")

  event        Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignedUser User? @relation("AssignedTasks", fields: [assignedTo], references: [id])
  doneBy       User? @relation("DoneTasks", fields: [doneById], references: [id])

  @@map("tasks")
}

model ChecklistItem {
  id              String         @id @default(cuid())
  eventId         String         @map("event_id")
  phase           ChecklistPhase @default(pre_production)
  title           String
  responsibleRole String?        @map("responsible_role")
  isDone          Boolean        @default(false) @map("is_done")
  doneAt          DateTime?      @map("done_at")
  doneByName      String?        @map("done_by_name")
  notes           String?
  sortOrder       Int            @default(0) @map("sort_order")
  createdAt       DateTime       @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

model MoodboardPeg {
  id          String   @id @default(cuid())
  eventId     String   @map("event_id")
  uploadedBy  String?  @map("uploaded_by")
  imageUrl    String   @map("image_url")
  caption     String?
  category    String?
  isApproved  Boolean  @default(false) @map("is_approved")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  event    Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploader User? @relation(fields: [uploadedBy], references: [id])

  @@map("moodboard_pegs")
}

model InventoryItem {
  id           String   @id @default(cuid())
  name         String
  category     String
  description  String?
  photoUrl     String?  @map("photo_url")
  totalQty     Int      @default(0) @map("total_qty")
  availableQty Int      @default(0) @map("available_qty")
  unit         String   @default("pc")
  condition    String   @default("good")
  notes        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  reservations Reservation[]

  @@map("inventory_items")
}

model Reservation {
  id              String            @id @default(cuid())
  eventId         String            @map("event_id")
  inventoryItemId String            @map("inventory_item_id")
  quantity        Int               @default(1)
  status          ReservationStatus @default(reserved)
  reservedFrom    DateTime          @map("reserved_from")
  reservedUntil   DateTime          @map("reserved_until")
  checkedOutAt    DateTime?         @map("checked_out_at")
  returnedAt      DateTime?         @map("returned_at")
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("reservations")
}

model Supplier {
  id             String   @id @default(cuid())
  name           String
  category       String
  contactPerson  String?  @map("contact_person")
  phone          String?
  email          String?
  address        String?
  notes          String?
  isPreferred    Boolean  @default(false) @map("is_preferred")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id             String   @id @default(cuid())
  eventId        String?  @map("event_id")
  supplierId     String   @map("supplier_id")
  poNumber       String   @unique @map("po_number")
  description    String?
  amount         Decimal  @default(0)
  status         String   @default("pending")
  expectedDate   DateTime? @map("expected_date")
  deliveredDate  DateTime? @map("delivered_date")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  supplier Supplier @relation(fields: [supplierId], references: [id])
  event    Event?   @relation(fields: [eventId], references: [id])

  @@map("purchase_orders")
}

model EventLog {
  id                 String   @id @default(cuid())
  eventId            String   @map("event_id")
  loggedBy           String?  @map("logged_by")
  logType            LogType  @default(note) @map("log_type")
  message            String
  photoUrl           String?  @map("photo_url")
  changeDescription  String?  @map("change_description")
  costImpact         Decimal? @map("cost_impact")
  isApprovedByClient Boolean? @map("is_approved_by_client")
  approvedByName     String?  @map("approved_by_name")
  loggedAt           DateTime @default(now()) @map("logged_at")

  event  Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  logger User? @relation(fields: [loggedBy], references: [id])

  @@map("event_logs")
}

model AfterEvent {
  id                  String   @id @default(cuid())
  eventId             String   @unique @map("event_id")
  clientFeedback      String?  @map("client_feedback")
  ratingOverall       Int?     @map("rating_overall")
  ratingDesign        Int?     @map("rating_design")
  ratingCoordination  Int?     @map("rating_coordination")
  ratingOnTime        Int?     @map("rating_on_time")
  ratingCrew          Int?     @map("rating_crew")
  ratingValue         Int?     @map("rating_value")
  wouldRecommend      Boolean? @map("would_recommend")
  allowTestimonial    Boolean  @default(false) @map("allow_testimonial")
  photosUploaded      Boolean  @default(false) @map("photos_uploaded")
  finalBalanceSettled Boolean  @default(false) @map("final_balance_settled")
  balanceSettledDate  DateTime? @map("balance_settled_date")
  nextBookingInterest Boolean? @map("next_booking_interest")
  nextEventType       String?  @map("next_event_type")
  nextEventNotes      String?  @map("next_event_notes")
  coordinatorNotes    String?  @map("coordinator_notes")
  issuesEncountered   String?  @map("issues_encountered")
  suggestions         String?
  submittedByClient   Boolean  @default(false) @map("submitted_by_client")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("after_events")
}

model EventFile {
  id               String   @id @default(cuid())
  eventId          String   @map("event_id")
  category         String   @default("other")
  originalFilename String   @map("original_filename")
  storedFilename   String   @map("stored_filename")
  fileUrl          String   @map("file_url")
  fileSizeKb       Int?     @map("file_size_kb")
  mimeType         String?  @map("mime_type")
  description      String?
  uploadedBy       String?  @map("uploaded_by")
  isClientVisible  Boolean  @default(false) @map("is_client_visible")
  createdAt        DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_files")
}

model Meeting {
  id             String   @id @default(cuid())
  clientName     String   @map("client_name")
  contactNo      String?  @map("contact_no")
  meetingDate    DateTime @map("meeting_date")
  meetingTime    DateTime @map("meeting_time")
  location       String
  packageAvailed String   @map("package_availed")
  packageNotes   String?  @map("package_notes")
  status         String   @default("scheduled")
  eventId        String?  @map("event_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@map("meetings")
}

model Review {
  id         String   @id @default(cuid())
  clientId   String   @map("client_id")
  rating     Int      @default(5)
  comment    String
  isFeatured Boolean  @default(false) @map("is_featured")
  createdAt  DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id])

  @@map("reviews")
}
